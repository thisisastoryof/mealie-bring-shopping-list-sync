# --- Mealie ----------------------------------------------------------
# Internal Docker network URL is preferred, e.g. http://mealie:9000
MEALIE_BASE_URL=http://mealie:9000
MEALIE_API_KEY=changeme
MEALIE_SHOPPING_LIST_ID=00000000-0000-0000-0000-000000000000

# --- Bring! ----------------------------------------------------------
BRING_EMAIL=you@example.com
BRING_PASSWORD=changeme
# Human-readable Bring list name; resolved to a UUID on startup.
BRING_LIST_NAME=Shopping

# --- Sync behaviour --------------------------------------------------
# Seconds between reconciliation cycles.
POLL_INTERVAL=60
# What to do in Mealie when an item is completed/removed in Bring:
#   check  -> mark the Mealie item checked (keeps history)
#   delete -> delete the Mealie item
ON_COMPLETE=check
# How to represent Bring-originated items in Mealie:
#   note -> add as a plain note item (default, safest)
#   food -> attempt to resolve to a Mealie food by name, fall back to note
BRING_TO_MEALIE=note
# Skip items edited within this many seconds to avoid syncing mid-edit.
FRESHNESS_DEBOUNCE_SECONDS=5
# Suspend polling during a local-time window (uses TIMEZONE below). Empty = always on.
# Example: QUIET_HOURS=23:00-07:00
QUIET_HOURS=

# --- System ----------------------------------------------------------
DB_PATH=/data/sync.db
TIMEZONE=Europe/Berlin
PORT=8000
LOG_LEVEL=INFO
