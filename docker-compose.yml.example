services:
  mealie-bring-sync:
    build: .
    image: mealie-bring-shopping-list-sync:latest
    restart: unless-stopped
    ports:
      # Only needed to reach /health from the host; the service takes no other inbound traffic.
      - "9931:8000"
    volumes:
      - ./sync-data:/data
    env_file:
      - .env
    healthcheck:
      test: ["CMD", "python", "-c", "import urllib.request; urllib.request.urlopen('http://localhost:8000/health')"]
      interval: 30s
      timeout: 5s
      start_period: 15s
    # Attach to the same network as your Mealie container so MEALIE_BASE_URL can
    # use the internal service name (e.g. http://mealie:9000).
    # networks:
    #   - mealie
# networks:
#   mealie:
#     external: true
